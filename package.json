{
  "name": "cicero-machine",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:awake": "caffeinate -dims npm run dev",
    "dev:web": "vite --host 127.0.0.1 --open /debate.html",
    "dev:server": "tsx watch server/index.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "build": "vite build && tsc --noEmit",
    "start": "NODE_ENV=production tsx server/index.ts",
    "start:awake": "caffeinate -dims npm start",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "express": "^4.21.2",
    "lucide": "^0.468.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
